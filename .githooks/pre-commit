#!/bin/sh
# Pre-commit hook: verify CLAUDE.md remains a symlink to AGENTS.md.

if [ -e "CLAUDE.md" ] && [ ! -L "CLAUDE.md" ]; then
    echo ""
    echo "ERROR: CLAUDE.md is not a symlink."
    echo "CLAUDE.md must be a symlink to AGENTS.md."
    echo "Run: ln -sf AGENTS.md CLAUDE.md"
    echo ""
    exit 1
fi

if [ -L "CLAUDE.md" ]; then
    TARGET=$(readlink CLAUDE.md)
    if [ "$TARGET" != "AGENTS.md" ]; then
        echo ""
        echo "ERROR: CLAUDE.md symlink points to '$TARGET', expected 'AGENTS.md'."
        echo "Run: ln -sf AGENTS.md CLAUDE.md"
        echo ""
        exit 1
    fi
fi
